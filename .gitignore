# --- Python & uv ---
# Python's auto-generated bytecode folders (makes code run faster locally) 
__pycache__/   
# Compiled Python files (individual versions of the above)        
*.py[cod]
# Compiled Python files for Jython (Java-based Python)         
*$py.class    
# Your local virtual environment; contains thousands of library files          
.venv/        
# Built package files (binaries) from pip or uv     
wheels/               

# --- Distribution / Build ---
# Temporary directory for building local packages 
build/          
# Folder containing final build artifacts for distribution       
dist/   
# Metadata generated by setuptools during installation                
*.egg-info/        
# Configuration files for PyInstaller (creating .exe files)       
*.spec              

# --- WSL / Windows / macOS Metadata ---
# macOS system file containing folder view preferences
.DS_Store         
# Windows system file containing thumbnail images for folders     
Thumbs.db          
# Windows system file for folder icon and display settings    
desktop.ini        
# Windows recycle bin data if working on an external drive     
$RECYCLE.BIN/          

# --- IDEs & Editors ---
# Your personal VS Code settings (theme, window size, local paths) 
.vscode/             
# JetBrains (PyCharm) project settings    
.idea/             
# "Swap" files: Temporary recovery files created by Vim/Unix editors    
*.swp                
# "Swap" files: Similar to .swp; created when editing the same file twice   
*.swo                 

# --- Local Environment Secrets ---
# DANGER: NEVER commit this. Contains API keys and private credentials 
.env
